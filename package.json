{
  "name": "template-node",
  "description": "A template for Node.js projects",
  "version": "1.0.0",
  "license": "MIT",
  "private": true,
  "type": "module",
  "author": "Mike Valeriano <mkvlrn@gmail.com>",
  "repository": {
    "type": "git",
    "url": "git@github.com:mkvlrn/template-node"
  },
  "keywords": [
    "node",
    "template"
  ],
  "scripts": {
    "test": "vitest --run",
    "test:cov": "rimraf coverage && vitest run --coverage",
    "prepare": "husky",
    "dev": "tsx watch src/main.ts",
    "lint": "eslint --fix src tests",
    "lint-staged": "lint-staged",
    "format": "prettier --write src tests",
    "type-check": "tsc --noEmit",
    "build": "rimraf dist && tsx esbuild.config.ts",
    "start": "node dist/main.js"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.4.1",
    "@commitlint/config-conventional": "^19.4.1",
    "@mkvlrn/eslint-config": "^24.8.12",
    "@mkvlrn/prettier-config": "^24.8.2",
    "@types/node": "^22.5.1",
    "@vitest/coverage-v8": "^2.0.5",
    "esbuild": "^0.23.1",
    "eslint": "^9.9.1",
    "husky": "^9.1.5",
    "lint-staged": "^15.2.9",
    "prettier": "^3.3.3",
    "rimraf": "^6.0.1",
    "tsc-alias": "^1.8.10",
    "tsx": "^4.19.0",
    "typescript": "^5.5.4",
    "vite-tsconfig-paths": "^5.0.1",
    "vitest": "^2.0.5"
  }
}
