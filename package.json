{
  "name": "template-node",
  "description": "A template for Node.js projects",
  "version": "1.0.0",
  "license": "MIT",
  "private": true,
  "type": "module",
  "author": "Mike Valeriano <mkvlrn@gmail.com>",
  "repository": {
    "type": "git",
    "url": "git@github.com:mkvlrn/template-node"
  },
  "keywords": [
    "node",
    "template"
  ],
  "scripts": {
    "test": "vitest --run",
    "test:cov": "rimraf coverage && vitest run --coverage",
    "prepare": "husky",
    "dev": "node --import @swc-node/register/esm-register --watch src/index.ts",
    "lint": "eslint src --fix",
    "lint-staged": "lint-staged",
    "format": "prettier --write src",
    "type-check": "tsc --noEmit",
    "build": "rimraf dist && swc src -d dist --ignore **/*.spec.ts --strip-leading-paths",
    "start": "node dist"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.3.0",
    "@commitlint/config-conventional": "^19.2.2",
    "@mkvlrn/eslint-config": "^24.6.9",
    "@mkvlrn/prettier-config": "^24.6.4",
    "@swc-node/register": "^1.9.2",
    "@swc/cli": "^0.3.12",
    "@swc/core": "^1.6.1",
    "@swc/plugin-transform-imports": "^2.0.5",
    "@swc/types": "^0.1.8",
    "@types/node": "^20.14.2",
    "@vitest/coverage-v8": "^1.6.0",
    "husky": "^9.0.11",
    "lint-staged": "^15.2.7",
    "rimraf": "^5.0.7",
    "typescript": "^5.4.5",
    "unplugin-swc": "^1.4.5",
    "vite-tsconfig-paths": "^4.3.2",
    "vitest": "^1.6.0"
  }
}
