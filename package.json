{
  "name": "template-node",
  "description": "A template for esm Node.js projects using typescript",
  "version": "1.0.0",
  "license": "MIT",
  "private": true,
  "type": "module",
  "author": "Mike Valeriano <mkvlrn@gmail.com>",
  "repository": {
    "type": "git",
    "url": "git@github.com:mkvlrn/template-node"
  },
  "keywords": [
    "node",
    "typescript",
    "esm",
    "template"
  ],
  "engines": {
    "node": "24.14.1",
    "pnpm": "10.33.0"
  },
  "imports": {
    "#/*": "./src/*.ts"
  },
  "scripts": {
    "dev": "node --watch ./src/main.ts",
    "start": "node ./src/main.ts",
    "lint": "pnpm lint-check --write",
    "lint-check": "biome check --diagnostic-level=warn --no-errors-on-unmatched",
    "typecheck": "tsc",
    "typecheck-staged": "tsc-files",
    "test": "vitest --config=./.config/vitest.ts",
    "test-staged": "vitest related --config=./.config/vitest.ts --bail=1 --reporter=github-actions",
    "test-ci": "vitest --config=./.config/vitest.ts --bail=1 --reporter=github-actions",
    "prepare": "lefthook install"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.10",
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@mkvlrn/config": "^3.1.11",
    "@types/node": "^25.5.2",
    "@vitest/coverage-v8": "^4.1.2",
    "lefthook": "^2.1.4",
    "tsc-files": "^1.1.4",
    "typescript": "^6.0.2",
    "vitest": "^4.1.2"
  }
}
